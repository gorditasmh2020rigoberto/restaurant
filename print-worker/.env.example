# ───────────────────────────────────────────────────────────────────
# Configuración del print-worker. Copia este archivo a `.env` y llena
# los valores. NO commitear `.env`.
# ───────────────────────────────────────────────────────────────────

# URL del proyecto Supabase (la misma que usa la PWA).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# SERVICE ROLE KEY (NO la anon key). La sacas del dashboard de
# Supabase → Project Settings → API → service_role. Esta key da
# acceso full a la BD — protégela: no la pegues en chats, ni la
# subas a git. Solo vive en este .env de la mini-PC.
SUPABASE_SERVICE_KEY=eyJ...

# ─── Target de impresión: usa UNO de los dos ───
#
# (A) Windows — nombre EXACTO como aparece en Devices and Printers
# (Panel de Control → Devices and Printers → click derecho → Printer
# properties → pestaña "General" → campo "Name").
PRINTER_NAME=Star TSP143 (TSP100)
#
# (B) Linux / Raspberry Pi — path del device USB (típicamente
# /dev/usb/lp0). Si tu user no está en el grupo `lp`, agrégalo con
# `sudo usermod -aG lp $USER` y vuelve a entrar. Comenta PRINTER_NAME
# arriba si vas a usar PRINTER_DEVICE.
# PRINTER_DEVICE=/dev/usb/lp0

# Tipo de set de comandos. Default: 'epson' (ESC/POS, lo más común,
# funciona en clones y en Star configurada en modo ESC/POS). Usa
# 'star' solo si tu Star está en Star Line Mode original.
# PRINTER_TYPE=epson

# Ancho de papel en columnas. 48 = papel de 80 mm (default).
# 32 = papel de 58 mm (mini, ~5 cm útiles).
# PAPER_WIDTH_CHARS=48

# Pausa en milisegundos entre el ticket de BAR y el de COCINA, para
# que el barman pueda cortar/agarrar el primero antes de que salga el
# segundo. Default 5000 (5 segundos). Pon 0 para imprimir los dos
# tickets pegados sin pausa.
# PAUSE_BETWEEN_TICKETS_MS=5000

# Nombre del restaurante que aparece como encabezado en cada ticket
# (en negritas y centrado, arriba del COCINA/BAR). Default
# "GORDITAS MIS HERMANAS".
# RESTAURANT_NAME=GORDITAS MIS HERMANAS

# Modo de visualización de cocina para esta sucursal:
#   'printer' (default) → imprime tickets en la impresora térmica.
#   'screen'            → la cocina usa la pantalla (kitchen_view de
#                         la PWA). El worker NO imprime; las órdenes
#                         se ven en vivo en la pantalla vía Realtime.
# Para cambiar entre modos: edita esta var y `sudo systemctl restart
# print-worker` en la Pi.
# DISPLAY_MODE=printer

# Sucursal que atiende esta impresora. El worker solo imprime órdenes
# de esta sucursal. Debe coincidir EXACTO con `orders.branch_name`
# en la BD — incluye el prefijo "Sucursal " (p.ej. "Sucursal Maravillas",
# "Sucursal Pocitos"). "Maravillas" a secas NO hace match con nada.
BRANCH_NAME=Sucursal Maravillas

# Filtro por área — para tener VARIAS Pis en la misma sucursal, cada
# una imprimiendo solo su parte.
#   '' (o no definir) → imprime TODO (COCINA + BAR en la misma Pi).
#                       Es el comportamiento original, compat.
#   'drinks'          → SOLO bebidas. Ticket titulado "BAR".
#                       (categorías: drink, alcohol, bebidas, drinks)
#   'kitchen'         → SOLO comida (todo lo que NO es bebida).
#                       Ticket titulado "COCINA".
#   'line'            → Mismo filtro que 'kitchen' pero el ticket se
#                       titula "LÍNEA DE PRODUCCIÓN". Usar en sucursales
#                       donde al área de comida se le dice "línea" y
#                       no "cocina" (p.ej. Pocitos).
#   'takeout'         → SOLO comida de órdenes to_go/delivery. Ticket
#                       titulado "PARA LLEVAR". Ignora PRINT_ORDER_TYPES
#                       (ya trae su propio filtro).
# Ejemplo de despliegue en Pocitos con 3 Pis:
#   Pi bebidas   → PRINT_AREA=drinks
#   Pi línea     → PRINT_AREA=line, PRINT_ORDER_TYPES=dine_in
#   Pi para llevar → PRINT_AREA=takeout
# Cada Pi marca solo sus items; cuando la última termina, la orden
# queda como impresa. Si dejas PRINT_AREA vacía en 2 Pis distintas,
# solo UNA va a imprimir cada orden (la que gane la carrera de UPDATE).
# PRINT_AREA=drinks

# Filtro por tipo de orden (dine_in, to_go, delivery). Comma-separated.
# Vacío / no definido → acepta todos los tipos.
# Ejemplos:
#   PRINT_ORDER_TYPES=dine_in           → solo para comer aquí
#   PRINT_ORDER_TYPES=to_go,delivery    → solo para llevar/domicilio
# Cuando PRINT_AREA=takeout esta variable se ignora (área ya filtra).
# PRINT_ORDER_TYPES=dine_in

# Solo aplica si PRINT_AREA=kitchen o line Y no configuraste
# PRINT_ORDER_TYPES arriba: cuánto espera (ms) antes de imprimir la
# comida de una orden To Go/Delivery, para darle tiempo a una Pi
# 'takeout' dedicada (si existe) de reclamarla primero y evitar
# duplicar el ticket. Default 6000. Configurar PRINT_ORDER_TYPES=dine_in
# sigue siendo más rápido (sin este retraso).
# TAKEOUT_GRACE_MS=6000

# DRY_RUN=true → no envía nada a la impresora; imprime el ticket
# formateado en la TERMINAL. Útil para desarrollo local (Mac/Linux
# sin impresora térmica). En la mini-PC de cocina déjalo en false
# o quita la línea.
DRY_RUN=false
