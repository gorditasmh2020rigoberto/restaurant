# ───────────────────────────────────────────────────────────────────
# Configuración del print-worker. Copia este archivo a `.env` y llena
# los valores. NO commitear `.env`.
# ───────────────────────────────────────────────────────────────────

# URL del proyecto Supabase (la misma que usa la PWA).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# SERVICE ROLE KEY (NO la anon key). La sacas del dashboard de
# Supabase → Project Settings → API → service_role. Esta key da
# acceso full a la BD — protégela: no la pegues en chats, ni la
# subas a git. Solo vive en este .env de la mini-PC.
SUPABASE_SERVICE_KEY=eyJ...

# Nombre EXACTO de la impresora como aparece en Windows.
# Para verlo: Panel de Control → Devices and Printers → click derecho
# en la impresora → Printer properties → pestaña "General" → campo
# "Name". Suele ser algo como "Star TSP143 (TSP100)" o similar.
PRINTER_NAME=Star TSP143 (TSP100)

# Sucursal que atiende esta impresora. El worker solo imprime órdenes
# de esta sucursal. Debe coincidir EXACTO con `orders.branch_name`
# en la BD (p.ej. "Maravillas", "Pocitos").
BRANCH_NAME=Maravillas

# DRY_RUN=true → no envía nada a la impresora; imprime el ticket
# formateado en la TERMINAL. Útil para desarrollo local (Mac/Linux
# sin impresora térmica). En la mini-PC de cocina déjalo en false
# o quita la línea.
DRY_RUN=false
